# auto-claude configuration
# Copy this file to config.toml and edit to match your environment:
#   cp config.toml.sample config.toml

[github]
org = "your-org"
repos = [
    "repo-one",
    "repo-two",
]
poll_interval_seconds = 60
base_branch = "main"        # branch to branch from and PR into
label_prefix = "ac-"
needs_info_label = "ac-needs-info"
pr_created_label = "ac-pr-created"
in_progress_label = "ac-in-progress"
plan_posted_label = "ac-plan-posted"
review_posted_label = "ac-review-posted"
action_labels = ["ac-fix", "ac-implement", "ac-test", "ac-plan", "ac-review"]
dev_actions = ["fix", "implement", "test"]
plan_actions = ["plan", "review"]

[claude]
triage_model = "claude-haiku-4-5"
dev_model = "claude-opus-4-6"
permission_mode = "bypassPermissions"
max_budget_usd = 5.0
output_format = "stream-json"

[workers]
max_parallel = 3
retry_max = 2
retry_delay_seconds = 30
shutdown_grace_seconds = 30

[paths]
repos_dir = "repos"
worktrees_dir = "worktrees"
state_file = "state/issues.json"
log_file = "logs/auto-claude.log"
prompts_dir = "prompts"

[logging]
level = "INFO"       # DEBUG | INFO | WARN | ERROR
colorize = true
log_to_file = true
